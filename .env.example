# ─────────────────────────────────────────────────────────────
# Boutique Headless Commerce — Environment Variables
#
# EVERYTHING BELOW IS OPTIONAL. With NO variables set, the app builds and runs
# in full "demo mode" (rich sample catalogue, browsable admin) — deploy it as-is
# to see everything. Add variables only to connect real services:
#   • Shopify        → live catalogue, cart, checkout, customer accounts
#   • DATABASE_URL   → multi-tenant registry + admin authentication
#   • Stripe         → subscription billing
# On Vercel the deployment URL is auto-detected, so even NEXT_PUBLIC_APP_URL
# is optional.
#
# Copy to `.env.local` and fill in what you need. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Root domain used to resolve tenant subdomains (e.g. "boutique.app")
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# ── Shopify Storefront API (default / demo tenant) ───────────
# Used when a tenant has no per-store credentials configured.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_public_token
SHOPIFY_STOREFRONT_API_VERSION=2025-01

# ── Shopify Admin API (server-only, never exposed) ───────────
SHOPIFY_ADMIN_ACCESS_TOKEN=your_admin_api_token
SHOPIFY_ADMIN_API_VERSION=2025-01

# ── Shopify OAuth (multi-tenant onboarding) ──────────────────
SHOPIFY_API_KEY=your_app_api_key
SHOPIFY_API_SECRET=your_app_api_secret
SHOPIFY_APP_SCOPES=read_products,read_orders,read_customers,read_inventory
SHOPIFY_WEBHOOK_SECRET=your_webhook_signing_secret

# ── Stripe (subscriptions / billing) ─────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRICE_BASIC=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# ── Database (tenant registry, subscriptions, settings) ──────
# The catalog itself is NEVER stored here — only tenant metadata.
DATABASE_URL=postgresql://user:pass@localhost:5432/boutique

# ── Auth / sessions ──────────────────────────────────────────
AUTH_SECRET=generate_a_long_random_string

# ── Super Admin ──────────────────────────────────────────────
SUPER_ADMIN_EMAILS=you@example.com
